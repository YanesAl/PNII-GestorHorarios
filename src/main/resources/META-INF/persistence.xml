<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="PU-GestorHorarios" transaction-type="JTA">

        <jta-data-source>java:jboss/datasources/horarios_ub</jta-data-source>

        <class>co.edu.unbosque.model.Grupo</class>
        <class>co.edu.unbosque.model.Curso</class>
        <class>co.edu.unbosque.model.Docente</class>
        <class>co.edu.unbosque.model.Estudiante</class>
        <class>co.edu.unbosque.model.Seccion</class>
        <class>co.edu.unbosque.model.Persona</class>

        <properties>
            <!-- Crea tablas si no existen, no borra datos -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>

            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>

    </persistence-unit>

</persistence>